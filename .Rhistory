group_by(SY) %>%
mutate(meansal = mean(Salinity_ppt), meanwd = mean(Water_depth), meantemp = mean(Temp), meandop = mean(DO_percent), meandomgl = mean(DO_mg_L), meanspc = mean(SPC), meantds = mean(TDS), meanph = mean(pH)) %>%
